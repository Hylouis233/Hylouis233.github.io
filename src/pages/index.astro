---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { profile } from '../data/profile';
import { projects, publications } from '../data/academic';
import { currentFocus, keywords, researchThemes, selectedHighlights } from '../data/research';

const iconMap = {
  orcid: '<path d="M9.9 7.8h4.2v13.4H9.9z"/><path d="M12 4.5a2.4 2.4 0 1 1 0 4.8 2.4 2.4 0 0 1 0-4.8Zm5.7 6.6c2.7 0 4.7 2 4.7 5.1 0 3.1-2 5.1-4.8 5.1h-4.4V11.1h4.5Zm-.4 2.5h-1.7v5.2h1.7c1.4 0 2.4-1 2.4-2.6 0-1.6-.9-2.6-2.4-2.6Z"/>',
  github: '<path d="M12 .6C5.7.6.7 5.6.7 11.9c0 5 3.2 9.1 7.6 10.6.6.1.8-.3.8-.6v-2.2c-3.1.7-3.7-1.3-3.7-1.3-.5-1.3-1.2-1.7-1.2-1.7-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 .1 1.9.7 2.3 1.8.9 1.5 2.3 1.1 2.8.8.1-.7.4-1.1.7-1.4-2.5-.3-5.2-1.2-5.2-5.5 0-1.2.4-2.2 1.2-3-.1-.3-.5-1.4.1-2.9 0 0 .9-.3 3 .9a10.4 10.4 0 0 1 5.4 0c2.1-1.2 3-.9 3-.9.6 1.5.2 2.6.1 2.9.8.8 1.2 1.8 1.2 3 0 4.3-2.7 5.2-5.2 5.5.4.4.8 1.1.8 2.1v3.1c0 .3.2.7.8.6 4.4-1.5 7.6-5.6 7.6-10.6C23.3 5.6 18.3.6 12 .6Z"/>',
  scholar: '<path d="M12 2 1 8l11 6 9-4.9V17h2V8L12 2Zm-6.8 9.3V15c0 2.8 4.1 5 6.8 5s6.8-2.2 6.8-5v-3.7L12 15l-6.8-3.7Z"/>',
  researchgate: '<path d="M5.5 3.2h7.2c4 0 6.5 2 6.5 5.6 0 2.5-1.4 4.3-3.7 5.1l4.1 6.9h-4.2l-3.6-6.3H9.2v6.3H5.5V3.2Zm6.8 8.1c2 0 3.1-.8 3.1-2.4s-1.1-2.4-3.1-2.4H9.2v4.8h3.1Z"/><path d="M4.3 16.3h4.5v4.5H4.3z"/>',
  email: '<path d="M2.3 5.5h19.4a1.3 1.3 0 0 1 1.3 1.3v10.4a1.3 1.3 0 0 1-1.3 1.3H2.3A1.3 1.3 0 0 1 1 17.2V6.8a1.3 1.3 0 0 1 1.3-1.3Zm9.7 6 9-5.2H3l9 5.2Zm0 1.6-9-5.1v8h18v-8l-9 5.1Z"/>',
} as const;

const featuredPublications = publications.filter((item) => item.featured);
const homepageStats = {
  firstAuthor: publications.filter((item) => item.authorshipRank === 'lead').length,
  published: publications.filter((item) => item.category === 'publication').length,
  repositories: projects.filter((item) => item.repoUrl).length,
};

const featuredProjects = projects.filter((item) => item.featured);
const highlightedOutputs = featuredPublications.slice(0, 3);
const utilityLinks = [
  { label: 'Research', href: '/research/' },
  { label: 'Publications', href: '/publications/' },
  { label: 'CV', href: '/cv/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Portfolio', href: profile.portfolioHref },
];
---
<BaseLayout title="Hong Liu | Home">
  <Hero />

  <div class="grid homepage-grid">
    <section class="panel-primary span-12 evidence-panel">
      <div class="section-header section-header-balanced">
        <div class="section-header-copy">
          <h2 class="section-title">Selected research outputs</h2>
          <p class="section-subtitle">Representative first-author and lead work appears first so the homepage communicates research direction and evidence before secondary context.</p>
        </div>
        <div class="stat-strip">
          <article class="stat-chip">
            <p class="stat-value">{homepageStats.firstAuthor}</p>
            <p class="stat-label">First-author studies</p>
          </article>
          <article class="stat-chip">
            <p class="stat-value">{homepageStats.published}</p>
            <p class="stat-label">Published papers</p>
          </article>
          <article class="stat-chip">
            <p class="stat-value">{homepageStats.repositories}</p>
            <p class="stat-label">Public repositories</p>
          </article>
        </div>
      </div>
      <div class="highlight-grid">
        {highlightedOutputs.map((item) => (
          <article class="highlight-card">
            <p class="item-kicker">{item.year} · {item.authorship?.en}</p>
            <h3>{item.title.en}</h3>
            <p class="highlight-meta">{item.venue.en} · {item.status.en}</p>
            <p>{item.note.en}</p>
            <div class="meta-row">
              {item.url && (
                <a href={item.url} target="_blank" rel="noreferrer" class="badge">View record</a>
              )}
              {item.relatedProjectKeys?.map((key) => {
                const project = projects.find((candidate) => candidate.key === key);
                return project ? (
                  <span class="badge badge-muted">Related system: {project.name.en}</span>
                ) : null;
              })}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="panel span-7 content-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Research focus</h2>
        <p class="section-subtitle">Current work is organized around a compact set of research themes rather than a long inventory of activities.</p>
      </div>
      <div class="list">
        {researchThemes.map((theme) => (
          <article class="card">
            <h3>{theme.title.en}</h3>
            <p>{theme.body.en}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel-secondary span-5 snapshot-panel content-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Current snapshot</h2>
        <p class="section-subtitle">A concise summary of the current research stage, active methods, and outward-facing profile links.</p>
      </div>
      <p>{currentFocus.en}</p>
      <div class="chip-row compact-chip-row">
        {keywords.map((keyword) => (
          <span class="chip chip-soft">{keyword}</span>
        ))}
      </div>
      <div class="snapshot-links divider-top">
        {profile.links.map((link) => (
          <a class="icon-link" href={link.href} target="_blank" rel="noreferrer" aria-label={link.label} title={link.label}>
            <span class="icon-link-icon" set:html={`<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">${iconMap[link.icon]}</svg>`} />
          </a>
        ))}
        <a href={profile.portfolioHref}>Portfolio</a>
      </div>
    </section>

    <section class="panel span-8 content-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Research software and analytical systems</h2>
        <p class="section-subtitle">Software artifacts are presented as supporting evidence for modelling, forecasting, data engineering, and research workflows.</p>
      </div>
      <div class="software-grid">
        {featuredProjects.map((item) => (
          <article class="software-card">
            <div class="software-header">
              <div>
                <p class="item-kicker">{item.type.replace('-', ' ')}</p>
                <h3>{item.name.en}</h3>
              </div>
            </div>
            <p>{item.summary.en}</p>
            {item.impactSummary && <p class="software-impact">{item.impactSummary.en}</p>}
            {item.tags && (
              <div class="chip-row compact-row">
                {item.tags.map((tag) => (
                  <span class="chip chip-soft">{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="panel-secondary span-4 content-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Selected highlights</h2>
        <p class="section-subtitle">Short evidence-led notes reinforce the main outputs without repeating the entire homepage narrative.</p>
      </div>
      <div class="list">
        {selectedHighlights.map((item) => (
          <article class="card">
            <p>{item.en}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel-secondary span-12 utility-panel content-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Navigate the site</h2>
        <p class="section-subtitle">Use the sections below for fuller research themes, publication records, CV material, and project context.</p>
      </div>
      <div class="chip-row compact-chip-row">
        {utilityLinks.map((item) => (
          <a class="chip chip-soft" href={item.href}>{item.label}</a>
        ))}
      </div>
    </section>
  </div>

  <style>
    .homepage-grid {
      align-items: start;
    }

    .content-panel {
      display: grid;
      align-content: start;
      gap: 22px;
    }

    .section-block-heading {
      display: grid;
      gap: 10px;
    }

    .evidence-panel {
      display: grid;
      gap: 24px;
    }

    .section-header-balanced {
      align-items: start;
    }

    .section-header-copy {
      display: grid;
      gap: 10px;
    }

    .stat-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: flex-start;
      align-self: start;
    }

    .stat-chip,
    .highlight-card,
    .software-card {
      padding: 20px;
      border-radius: var(--radius-md);
      border: 1px solid rgba(29, 36, 48, 0.08);
      background: rgba(255, 255, 255, 0.62);
    }

    .stat-chip {
      min-width: 152px;
      background: rgba(255, 255, 255, 0.72);
    }

    .stat-value {
      margin: 0;
      font-size: 1.9rem;
      line-height: 1;
      color: var(--accent);
    }

    .stat-label,
    .highlight-meta,
    .software-impact {
      margin: 8px 0 0;
      color: var(--muted);
    }

    .highlight-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: stretch;
    }

    .software-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: stretch;
    }

    .highlight-card h3,
    .software-card h3 {
      margin: 8px 0 0;
      line-height: 1.4;
    }

    .software-header {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: flex-start;
    }

    .compact-row,
    .compact-chip-row {
      gap: 8px;
    }

    .compact-row {
      margin-top: 14px;
    }

    .chip-soft {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(29, 36, 48, 0.08);
      color: var(--accent);
    }

    .snapshot-panel p:first-of-type {
      margin-top: 0;
    }

    .snapshot-links {
      display: grid;
      gap: 10px;
      margin-top: 8px;
      align-content: start;
    }

    .snapshot-links a {
      width: fit-content;
      padding: 0 0 2px;
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid rgba(22, 50, 79, 0.24);
      transition: border-color 0.2s ease, color 0.2s ease;
    }

    .snapshot-links a:hover {
      color: var(--gold);
      border-bottom-color: rgba(143, 110, 45, 0.45);
    }

    .utility-panel {
      padding-top: 24px;
    }

    @media (max-width: 960px) {
      .highlight-grid,
      .software-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
