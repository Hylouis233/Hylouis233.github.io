---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { profile } from '../data/profile';
import { projects, publications } from '../data/academic';
import { currentFocus, keywords, researchThemes, selectedHighlights } from '../data/research';

const iconMap = {
  orcid: '<path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/>',
  github: '<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>',
  scholar: '<path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/>',
  researchgate: '<path d="M19.586 0c2.273 0 4.146 1.82 4.414 4.072v15.856c-.268 2.252-2.141 4.072-4.414 4.072H4.414C2.141 24 .268 22.18 0 19.928V4.072C.268 1.82 2.141 0 4.414 0h15.172zm-7.31 9.522c-.663-.332-1.637-.47-2.612-.47-2.612 0-4.325 1.258-4.325 3.75 0 2.506 1.7 3.708 4.27 3.708 1.146 0 2.03-.236 2.514-.47v-2.31h-2.14v-1.18h3.76v3.136c-.95.594-2.333.882-3.882.882-3.414 0-5.748-1.74-5.748-4.962 0-3.11 2.307-5.066 5.885-5.066 1.436 0 2.762.33 3.62.83l-1.342 2.152zm4.398-1.57h1.587c.717 0 1.135-.29 1.135-.91 0-.648-.445-.882-1.228-.882h-1.494v1.792zm0 1.284v2.793h-1.256V6.696h2.822c1.477 0 2.494.636 2.494 1.95 0 1.12-.823 1.646-1.618 1.826l1.826 2.556H25.32l-1.534-2.27h-.98v2.27h-1.255z"/>',
  gmail: '<path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/>',
  qq: '<path d="M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-2.096 16.73c-.947 0-1.722-.76-1.722-1.69 0-.932.775-1.69 1.722-1.69.947 0 1.72.758 1.72 1.69 0 .93-.773 1.69-1.72 1.69zm6.192 0c-.947 0-1.722-.76-1.722-1.69 0-.932.775-1.69 1.722-1.69.947 0 1.72.758 1.72 1.69 0 .93-.773 1.69-1.72 1.69zm-6.192-5.412c-2.31 0-4.186-1.878-4.186-4.192 0-2.314 1.876-4.193 4.186-4.193 2.31 0 4.186 1.88 4.186 4.193 0 2.314-1.876 4.192-4.186 4.192zm6.192 0c-2.31 0-4.186-1.878-4.186-4.192 0-2.314 1.876-4.193 4.186-4.193 2.31 0 4.186 1.88 4.186 4.193 0 2.314-1.876 4.192-4.186 4.192z"/>',
} as const;

const featuredPublications = publications.filter((item) => item.featured);
const homepageStats = {
  firstAuthor: publications.filter((item) => item.authorshipRank === 'lead').length,
  published: publications.filter((item) => item.category === 'publication').length,
  repositories: projects.filter((item) => item.repoUrl).length,
};

const featuredProjects = projects.filter((item) => item.featured).slice(0, 4);
const highlightedOutputs = featuredPublications.slice(0, 3);
const utilityLinks = [
  { label: 'Research', href: '/research/' },
  { label: 'Publications', href: '/publications/' },
  { label: 'CV', href: '/cv/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Portfolio', href: profile.portfolioHref },
];
---
<BaseLayout title="Hong Liu | Home">
  <Hero />

  <div class="grid homepage-grid">
    <section class="panel-primary span-12 evidence-panel primary-evidence-panel">
      <div class="section-header section-header-balanced evidence-header">
        <div class="section-header-copy">
          <h2 class="section-title">Selected research outputs</h2>
          <p class="section-subtitle">Representative first-author and lead work appears first so the homepage communicates research direction and evidence before secondary context.</p>
        </div>
        <div class="stat-strip" aria-label="Homepage research statistics">
          <article class="stat-chip">
            <p class="stat-value">{homepageStats.firstAuthor}</p>
            <p class="stat-label">First-author studies</p>
          </article>
          <article class="stat-chip">
            <p class="stat-value">{homepageStats.published}</p>
            <p class="stat-label">Published papers</p>
          </article>
          <article class="stat-chip">
            <p class="stat-value">{homepageStats.repositories}</p>
            <p class="stat-label">Public repositories</p>
          </article>
        </div>
      </div>
      <div class="highlight-grid">
        {highlightedOutputs.map((item, index) => (
          <article class={`highlight-card ${index === 0 ? 'highlight-card-featured' : ''}`}>
            <p class="item-kicker">{item.year} · {item.authorship?.en}</p>
            <h3>{item.title.en}</h3>
            <p class="highlight-meta">{item.venue.en} · {item.status.en}</p>
            <p>{item.note.en}</p>
            <div class="meta-row output-meta-row">
              {item.url && (
                <a href={item.url} target="_blank" rel="noreferrer" class="badge">View record</a>
              )}
              {item.relatedProjectKeys?.map((key) => {
                const project = projects.find((candidate) => candidate.key === key);
                return project ? (
                  <span class="badge badge-muted">Related system: {project.name.en}</span>
                ) : null;
              })}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="panel span-7 content-panel focus-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Research focus</h2>
        <p class="section-subtitle">Current work is organized around a compact set of research themes rather than a long inventory of activities.</p>
      </div>
      <div class="list focus-list">
        {researchThemes.map((theme) => (
          <article class="card focus-card">
            <h3>{theme.title.en}</h3>
            <p>{theme.body.en}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel-secondary span-5 snapshot-panel content-panel auxiliary-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Current snapshot</h2>
        <p class="section-subtitle">A concise summary of the current research stage, active methods, and outward-facing profile links.</p>
      </div>
      <p>{currentFocus.en}</p>
      <div class="chip-row compact-chip-row">
        {keywords.map((keyword) => (
          <span class="chip chip-soft">{keyword}</span>
        ))}
      </div>
      <div class="snapshot-links divider-top">
        <div class="snapshot-icon-links" aria-label="External profile links">
          {profile.links.map((link) => (
            <a class="icon-link" href={link.href} target="_blank" rel="noreferrer" aria-label={link.label} title={link.label}>
              <span class="icon-link-icon" set:html={`<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">${iconMap[link.icon]}</svg>`} />
            </a>
          ))}
        </div>
        <a class="snapshot-text-link" href={profile.portfolioHref}>Portfolio</a>
      </div>
    </section>

    <section class="panel span-8 content-panel software-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Research software and analytical systems</h2>
        <p class="section-subtitle">Software artifacts are presented as supporting evidence for modelling, forecasting, data engineering, and research workflows.</p>
      </div>
      <div class="software-grid">
        {featuredProjects.map((item) => (
          <article class="software-card">
            <div class="software-header">
              <div>
                <p class="item-kicker">{item.type.replace('-', ' ')}</p>
                <h3>{item.name.en}</h3>
              </div>
            </div>
            <p>{item.summary.en}</p>
            {item.impactSummary && <p class="software-impact">{item.impactSummary.en}</p>}
            {item.tags && (
              <div class="chip-row compact-row subdued-chip-row">
                {item.tags.map((tag) => (
                  <span class="chip chip-soft">{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="panel-secondary span-4 content-panel highlight-notes-panel auxiliary-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Selected highlights</h2>
        <p class="section-subtitle">Short evidence-led notes reinforce the main outputs without repeating the entire homepage narrative.</p>
      </div>
      <div class="list compact-list">
        {selectedHighlights.map((item) => (
          <article class="card compact-card">
            <p>{item.en}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel-secondary span-12 utility-panel auxiliary-panel content-panel">
      <div class="section-block-heading">
        <h2 class="section-title">Navigate the site</h2>
        <p class="section-subtitle">Use the sections below for fuller research themes, publication records, CV material, and project context.</p>
      </div>
      <div class="chip-row compact-chip-row utility-links-row">
        {utilityLinks.map((item) => (
          <a class="badge badge-muted" href={item.href}>{item.label}</a>
        ))}
      </div>
    </section>
  </div>

  <style>
    .homepage-grid {
      align-items: stretch;
      margin-top: 48px;
      row-gap: 30px;
    }

    .content-panel {
      display: grid;
      align-content: start;
      gap: 20px;
    }

    .section-block-heading {
      display: grid;
      gap: 8px;
    }

    .evidence-panel {
      display: grid;
      gap: 24px;
    }

    .primary-evidence-panel {
      padding-top: 38px;
      padding-bottom: 38px;
    }

    .section-header-balanced {
      align-items: start;
    }

    .evidence-header {
      margin-bottom: 2px;
    }

    .section-header-copy {
      display: grid;
      gap: 8px;
    }

    .stat-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-start;
      align-self: start;
    }

    .stat-chip,
    .highlight-card,
    .software-card {
      padding: 20px;
      border-radius: var(--radius-md);
      border: 1px solid rgba(29, 36, 48, 0.06);
      background: rgba(255, 255, 255, 0.58);
      min-width: 0;
    }

    .stat-chip {
      min-width: 146px;
      background: rgba(255, 255, 255, 0.62);
    }

    .stat-value {
      margin: 0;
      font-size: 1.8rem;
      line-height: 1;
      color: var(--accent);
    }

    .stat-label,
    .highlight-meta,
    .software-impact {
      margin: 6px 0 0;
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.55;
    }

    .highlight-grid {
      display: grid;
      gap: 18px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: stretch;
    }

    .software-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: stretch;
    }

    .highlight-card,
    .software-card {
      display: grid;
      align-content: start;
      gap: 10px;
    }

    .highlight-card {
      background: rgba(255, 255, 255, 0.5);
    }

    .highlight-card-featured {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(245, 245, 245, 0.64));
      box-shadow: 0 24px 46px rgba(22, 50, 79, 0.08);
    }

    .software-card {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(245, 245, 245, 0.5));
    }

    .highlight-card h3,
    .software-card h3,
    .focus-card h3 {
      margin: 0;
      line-height: 1.3;
      text-wrap: balance;
    }

    .highlight-card p,
    .software-card p {
      margin: 0;
    }

    .software-header {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: flex-start;
    }

    .focus-list,
    .compact-list {
      gap: 0;
    }

    .focus-card {
      padding-top: 20px;
      padding-bottom: 20px;
    }

    .compact-card {
      padding-top: 16px;
      padding-bottom: 16px;
    }

    .output-meta-row,
    .compact-row,
    .compact-chip-row {
      gap: 8px;
    }

    .output-meta-row,
    .compact-row {
      margin-top: 4px;
    }

    .subdued-chip-row .chip,
    .snapshot-panel .chip,
    .utility-links-row .chip {
      background: rgba(255, 255, 255, 0.52);
      border: 1px solid rgba(29, 36, 48, 0.06);
      color: var(--accent);
    }

    .chip-soft {
      background: rgba(255, 255, 255, 0.58);
      border: 1px solid rgba(29, 36, 48, 0.06);
      color: var(--accent);
    }

    .auxiliary-panel {
      background: linear-gradient(180deg, rgba(248, 248, 248, 0.68), rgba(250, 250, 250, 0.56));
    }

    .snapshot-panel p:first-of-type {
      margin-top: 0;
    }

    .snapshot-links {
      display: grid;
      gap: 10px;
      margin-top: 4px;
      align-content: start;
    }

    .snapshot-icon-links {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .snapshot-text-link {
      width: fit-content;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.56);
      border: 1px solid rgba(29, 36, 48, 0.06);
      color: var(--accent);
      transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    }

    .snapshot-text-link:hover,
    .snapshot-text-link:focus-visible {
      background: var(--surface-strong);
      border-color: var(--line-strong);
      transform: translateY(-1px);
      outline: none;
    }

    .utility-panel {
      padding-top: 24px;
      padding-bottom: 24px;
    }

    .utility-links-row {
      margin-top: 2px;
    }

    @media (max-width: 960px) {
      .highlight-grid,
      .software-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
