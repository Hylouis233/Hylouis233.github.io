---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile, iconMap } from '../data/profile';
---
<BaseLayout title="Hong Liu | Contact">
  <div class="grid">
    <section class="panel span-7">
      <h2 class="section-title">Contact</h2>
      <p class="section-subtitle">For academic communication, research collaboration, software discussion, or related inquiries, the following channels are available.</p>
      <div class="list" style="margin-top: 24px;">
        <div class="hero-links" aria-label="Academic profile links">
          {profile.links.map((link) => (
            <a class="icon-link" href={link.href} target="_blank" rel="noreferrer" aria-label={link.label} title={link.label}>
              <span class="icon-link-icon" set:html={`<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">${iconMap[link.icon]}</svg>`} />
            </a>
          ))}
          <a class="icon-link" href={profile.cvHref} target="_blank" rel="noreferrer" aria-label="Download CV" title="Download CV">
            <span class="icon-link-icon" set:html={`<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>`} />
          </a>
        </div>
      </div>

      <div style="margin-top: 48px;">
        <h2 class="section-title">Support My Work</h2>
        <p class="section-subtitle">Open Science & Reproducible Research</p>
        
        <div class="sponsors-text" style="margin-top: 24px;">
          <p><strong>💡 My Passion & What Drives Me</strong></p>
          <p>I am currently an M.Sc. student specializing in <strong>infectious disease forecasting, spatiotemporal dynamics, and viral evolution</strong>. I am deeply passionate about bridging the gap between data science, machine learning, and epidemiology. What drives me every day is the belief that by deciphering complex health data and building robust prediction models, we can provide earlier warnings for public health challenges.</p>
          
          <p style="margin-top: 16px;"><strong>🛠️ What I Do</strong></p>
          <p>Through my research and GitHub repositories, I work on translating complex epidemiological models and multimodal forecasting algorithms into open-source, reproducible code. I strive to share my workflows and tools to help fellow researchers and developers in the community.</p>
        </div>

        <div class="sponsor-action-card" style="margin-top: 24px;">
          <p><strong>🌱 How Your Contributions Make a Difference</strong></p>
          <p class="sponsor-impact-text">Your sponsorship helps cover computing resources (servers/GPUs), research & maintenance costs, and fuels the late nights of debugging!</p>
          <div class="sponsor-btn-wrapper">
            <a href="https://buymeacoffee.com/liuh200107q" target="_blank" rel="noreferrer" class="bmc-btn">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                <path d="M20.216 1.792H3.576C2.158 1.792 1 2.95 1 4.368v11.595c0 1.418 1.158 2.576 2.576 2.576h1.792c0 2.138 1.733 3.871 3.871 3.871h5.31c2.138 0 3.871-1.733 3.871-3.871h1.792c1.418 0 2.576-1.158 2.576-2.576V4.368c0-1.418-1.158-2.576-2.576-2.576zm-1.792 14.171h-1.792v-3.871h1.792v3.871zm0-5.663h-1.792v-3.87h1.792v3.87z"/>
              </svg>
              Buy me a coffee
            </a>
          </div>
        </div>
      </div>
    </section>
    <section class="panel span-5">
      <h2 class="section-title">Preferred topics</h2>
      <div class="list">
        <article class="card">
          <h3>Research collaboration</h3>
          <p>Infectious disease forecasting and early warning, influenza co-circulation analysis, outbreak modelling, and research-oriented data platforms.</p>
        </article>
        <article class="card">
          <h3>Academic materials</h3>
          <p>CV requests, publication references, project summaries, and profile materials.</p>
        </article>
        <article class="card">
          <h3>Code and tooling</h3>
          <p>Discussion around repositories, modelling pipelines, data workflows, and reusable scientific tooling.</p>
        </article>
        <article class="card">
          <h3>Project portfolio</h3>
          <p>The portfolio entry is now hosted inside this site and currently serves as a compatibility placeholder for future Vue and demo layers.</p>
          <a class="icon-link" href={profile.portfolioHref} target="_blank" rel="noreferrer" aria-label="Portfolio" title="Portfolio" style="margin-top: 12px;">
            <span class="icon-link-icon" set:html={`<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M4 6h18V4H4c-1.1 0-2 .9-2 2v11H0v3h14v-3H4V6zm19 2h-6c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h6c.55 0 1-.45 1-1V9c0-.55-.45-1-1-1zm-1 9h-4v-7h4v7z"/></svg>`} />
          </a>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .sponsors-text p {
    margin: 0;
    line-height: 1.6;
  }

  .sponsor-action-card {
    padding: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(245, 245, 245, 0.5));
    border-radius: var(--radius-md);
    border: 1px solid rgba(29, 36, 48, 0.06);
  }

  .sponsor-impact-text {
    margin-top: 12px;
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.55;
  }

  .sponsor-btn-wrapper {
    margin-top: 20px;
  }

  .bmc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background-color: #FFDD00;
    color: #000000;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .bmc-btn:hover {
    transform: translateY(-2px);
    filter: brightness(0.95);
  }
</style>
