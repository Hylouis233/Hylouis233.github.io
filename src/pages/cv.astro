---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';
import { cvData, publicationGroups } from '../data/academic';

const contactLinks = profile.links.map((link) => ({
  label: link.label,
  href: link.href,
  text: link.href.replace('mailto:', ''),
}));

const publicationsByGroup = publicationGroups
  .map((group) => ({
    ...group,
    items: cvData.publications
      .filter((item) => item.category === group.key)
      .sort((a, b) => b.year - a.year),
  }))
  .filter((group) => group.items.length > 0);

const sortedProjects = [...cvData.projects].sort((a, b) => {
  const aYear = Math.max(
    ...(a.relatedPublicationTitles?.map((title) => {
      const publication = cvData.publications.find((item) => item.title.en === title);
      return publication?.year ?? 0;
    }) ?? [0]),
  );
  const bYear = Math.max(
    ...(b.relatedPublicationTitles?.map((title) => {
      const publication = cvData.publications.find((item) => item.title.en === title);
      return publication?.year ?? 0;
    }) ?? [0]),
  );
  return bYear - aYear;
});

const sortedAwards = [...cvData.awards].sort((a, b) => b.year - a.year);
---
<BaseLayout title="Hong Liu | CV">
  <div class="cv-page">
    <header class="cv-header">
      <p class="cv-label">Curriculum Vitae</p>
      <h1>{profile.name.en}</h1>
      <p class="cv-headline">{profile.degrees.en}</p>
      <p class="cv-summary">{profile.intro.en}</p>
      <div class="cv-contact">
        {contactLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer">{link.label}: {link.text}</a>
        ))}
        <a href={profile.cvHref} target="_blank" rel="noreferrer">PDF: Download CV</a>
      </div>
    </header>

    <section class="cv-section">
      <h2>Profile</h2>
      <p>Current work centers on documented master-stage research in infectious disease forecasting, influenza co-circulation analysis, outbreak modelling, and related research software. Publication states are presented conservatively and separated by category.</p>
    </section>

    <section class="cv-section">
      <h2>Education</h2>
      {cvData.education.map((item) => (
        <article class="cv-entry">
          <h3>{item.institution.en}</h3>
          <p class="cv-meta">{item.program.en} · {item.meta.en}</p>
          <p>{item.detail.en}</p>
        </article>
      ))}
    </section>

    <section class="cv-section">
      <h2>Research Interests</h2>
      <ul>
        {cvData.researchInterests.map((item) => (
          <li>{item.en}</li>
        ))}
      </ul>
    </section>

    <section class="cv-section">
      <h2>Publications and Manuscripts</h2>
      {publicationsByGroup.map((group) => (
        <div class="cv-subsection">
          <h3 class="cv-subtitle">{group.title.en}</h3>
          {group.items.map((item) => (
            <article class="cv-entry">
              <p class="cv-meta">{item.year} · {item.venue.en}</p>
              <h3>{item.title.en}</h3>
              <p><strong>Status:</strong> {item.status.en}</p>
              {item.authorship && <p class="cv-meta">{item.authorship.en}</p>}
              <p>{item.note.en}</p>
              {(item.url || item.doi || item.manuscriptId) && (
                <p class="cv-links">
                  {item.url && <a href={item.url} target="_blank" rel="noreferrer">{item.url}</a>}
                  {!item.url && item.doi && <span>DOI: {item.doi}</span>}
                  {item.manuscriptId && <span>Manuscript ID: {item.manuscriptId}</span>}
                </p>
              )}
            </article>
          ))}
        </div>
      ))}
    </section>

    <section class="cv-section">
      <h2>Research Software and Projects</h2>
      {sortedProjects.map((item) => (
        <article class="cv-entry">
          <h3>{item.name.en}</h3>
          <p class="cv-meta">{item.status.en}</p>
          <p>{item.summary.en}</p>
          {item.repoUrl ? (
            <p class="cv-links"><a href={item.repoUrl} target="_blank" rel="noreferrer">{item.repoUrl}</a></p>
          ) : (
            <p class="cv-meta">No public repository link is shown for this item.</p>
          )}
        </article>
      ))}
    </section>

    <section class="cv-section">
      <h2>Awards</h2>
      <ul>
        {sortedAwards.map((item) => (
          <li>{item.year} · {item.title.en}{item.issuer ? ` · ${item.issuer.en}` : ''}</li>
        ))}
      </ul>
    </section>

    <section class="cv-section">
      <h2>Experience</h2>
      {cvData.experience.map((item) => (
        <article class="cv-entry">
          <h3>{item.title.en}</h3>
          <p class="cv-meta">{[item.period?.en, item.organization?.en].filter(Boolean).join(' · ')}</p>
          <p>{item.detail.en}</p>
        </article>
      ))}
    </section>
  </div>

  <style>
    .cv-page {
      max-width: 820px;
      margin: 0 auto;
      padding: 0 8px;
      color: var(--text);
    }

    .cv-header {
      border-bottom: 1px solid var(--line);
      padding-bottom: 20px;
      margin-bottom: 24px;
    }

    .cv-label {
      margin: 0 0 8px;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .cv-header h1 {
      margin: 0;
      font-size: clamp(2.1rem, 5vw, 3rem);
      line-height: 1.05;
      color: var(--text);
    }

    .cv-headline,
    .cv-summary {
      margin: 10px 0 0;
      color: var(--text);
      line-height: 1.6;
    }

    .cv-contact {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 18px;
      margin-top: 14px;
      font-size: 0.95rem;
      color: var(--muted);
    }

    .cv-contact a,
    .cv-links a {
      text-decoration: underline;
      text-underline-offset: 0.12em;
    }

    .cv-section {
      padding: 18px 0;
      border-top: 1px solid var(--line);
    }

    .cv-section:first-of-type {
      border-top: none;
      padding-top: 0;
    }

    .cv-section h2 {
      margin: 0 0 12px;
      font-size: 1rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text);
    }

    .cv-section p,
    .cv-section li {
      margin: 0;
      line-height: 1.7;
      color: var(--text);
    }

    .cv-section ul {
      margin: 0;
      padding-left: 20px;
      display: grid;
      gap: 8px;
    }

    .cv-entry {
      padding: 10px 0;
      border-top: 1px solid rgba(31, 36, 48, 0.08);
    }

    .cv-entry:first-child {
      border-top: none;
      padding-top: 0;
    }

    .cv-entry h3,
    .cv-subtitle {
      margin: 0;
      font-size: 1rem;
      color: var(--text);
    }

    .cv-subsection + .cv-subsection {
      margin-top: 20px;
    }

    .cv-subtitle {
      margin-bottom: 8px;
      color: var(--accent);
    }

    .cv-entry p {
      margin-top: 4px;
    }

    .cv-meta {
      color: var(--muted);
    }

    .cv-links {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 16px;
      font-size: 0.95rem;
      color: var(--muted);
    }

    @media (max-width: 720px) {
      .cv-page {
        padding: 0;
      }

      .cv-contact {
        flex-direction: column;
        gap: 4px;
      }
    }
  </style>
</BaseLayout>
