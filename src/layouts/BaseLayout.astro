---
import { navigation, profile, siteMeta, iconMap } from '../data/profile';

interface Props {
  title: string;
}

const { title } = Astro.props as Props;
const portfolioHref = profile.portfolioHref;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={siteMeta.description} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%230056b3'/%3E%3Ctext x='32' y='43' font-size='30' font-weight='bold' text-anchor='middle' fill='white' font-family='Arial, Helvetica, sans-serif'%3EH%3C/text%3E%3C/svg%3E" />
    <style is:global>
      :root {
        --bg: #ffffff;
        --surface: #ffffff;
        --surface-strong: #fafafa;
        --surface-muted: #f5f5f5;
        --surface-quiet: #f0f0f0;
        --text: #222222;
        --muted: #555555;
        --muted-soft: #777777;
        --line: #e0e0e0;
        --line-strong: #cccccc;
        --accent: #0056b3; /* Academic blue */
        --accent-soft: rgba(0, 86, 179, 0.1);
        --gold: #0056b3; /* Replace gold with academic blue */
        --shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
        --shadow-soft: 0 2px 6px rgba(0, 0, 0, 0.03);
        --radius-lg: 8px; /* More professional, less rounded */
        --radius-md: 6px;
        --radius-sm: 4px;
        --measure: 75ch;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; /* Journal sans-serif */
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }
      p, li { max-width: var(--measure); }
      .shell { max-width: 1140px; margin: 0 auto; padding: 20px 24px 28px; }
      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 20px;
        padding: 12px 0 22px;
        border-bottom: 1px solid var(--line-strong);
      }
      .brand h1 {
        margin: 0;
        font-size: 1.35rem;
        letter-spacing: 0.02em;
        font-weight: 600;
      }
      .brand p {
        margin: 8px 0 0;
        color: var(--muted);
        font-size: 0.93rem;
      }
      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        justify-content: flex-end;
      }
      .nav a,
      .footer-links a,
      .icon-link {
        padding: 9px 14px;
        border-radius: var(--radius-sm);
        background: var(--surface-muted);
        border: 1px solid var(--line);
        transition: background-color 0.2s ease, border-color 0.2s ease;
      }
      .nav a:hover,
      .footer-links a:hover,
      .icon-link:hover,
      .nav a:focus-visible,
      .footer-links a:focus-visible,
      .icon-link:focus-visible {
        background: var(--accent-soft);
        color: var(--accent);
        border-color: var(--accent);
        outline: none;
      }
      .page { padding: 50px 0 96px; }
      .hero-card,
      .panel,
      .panel-primary,
      .panel-secondary {
        border-radius: var(--radius-lg);
        border: 1px solid var(--line);
        background: var(--surface);
      }
      .hero-card,
      .panel-primary {
        background: var(--surface);
        box-shadow: var(--shadow);
      }
      .panel {
        background: var(--surface-strong);
        box-shadow: var(--shadow-soft);
      }
      .panel-secondary {
        background: var(--surface-muted);
        box-shadow: none;
      }
      .hero-card {
        display: grid;
        grid-template-columns: minmax(0, 1.38fr) minmax(280px, 0.78fr);
        gap: 44px;
        padding: 52px;
        align-items: start;
      }

      .hero-copy {
        display: grid;
        align-content: start;
        gap: 16px;
      }
      .hero-side {
        display: grid;
        gap: 18px;
        align-content: start;
        padding-top: 6px;
      }
      .hero-facts-card,
      .hero-output-card,
      .evidence-strip {
        padding: 22px;
        border-radius: var(--radius-md);
        background: var(--surface-strong);
        border: 1px solid var(--line);
      }
      .eyebrow {
        margin: 0;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.75rem;
        font-weight: 600;
      }
      .hero-copy h1 {
        margin: 4px 0 0;
        font-size: clamp(3rem, 7vw, 4.5rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        font-weight: 700;
      }
      .headline {
        margin: 4px 0 0;
        font-size: clamp(1.12rem, 2vw, 1.32rem);
        color: var(--text);
        max-width: 26ch;
        line-height: 1.5;
        font-weight: 500;
        white-space: pre-wrap;
      }
      .muted,
      .summary,
      .list p,
      .card p,
      li,
      .footer,
      .section-subtitle {
        color: var(--muted);
        line-height: 1.6;
      }
      .summary {
        margin: 0;
        font-size: 1.05rem;
        max-width: 65ch;
      }
      .summary-secondary {
        color: var(--muted-soft);
        font-size: 0.96rem;
        max-width: 60ch;
      }
      .hero-links,
      .chip-row,
      .meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }
      .hero-links {
        margin-top: 2px;
        align-items: center;
      }
      .hero-links a,
      .chip,
      .badge {
        padding: 6px 12px;
        border-radius: var(--radius-sm);
        background: var(--surface-muted);
        color: var(--text);
        border: 1px solid var(--line);
      }
      .hero-links a:hover,
      .badge:hover,
      .chip:hover {
        background: var(--accent-soft);
        color: var(--accent);
        border-color: var(--accent);
      }
      .hero-links a,
      .chip,
      .badge,
      .nav a,
      .footer-links a {
        font-size: 0.85rem;
        font-weight: 500;
      }
      .icon-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        padding: 0;
        color: var(--muted);
        background: var(--surface);
        flex: 0 0 auto;
      }
      .icon-link:hover {
        color: var(--accent);
      }
      .icon-link-icon,
      .icon-link-icon svg {
        width: 18px;
        height: 18px;
        display: block;
        fill: currentColor;
      }
      .chip,
      .badge {
        font-size: 0.82rem;
        line-height: 1.32;
      }
      .badge-muted {
        background: var(--surface);
        border-color: var(--line);
        color: var(--muted);
      }
      .hero-image-wrap {
        display: flex;
        align-items: flex-start;
        justify-content: center;
      }
      .hero-image {
        width: 100%;
        max-width: 180px;
        border-radius: var(--radius-lg);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        transform: scaleX(-1);
      }
      .hero-facts-list,
      .hero-output-list,
      .evidence-grid,
      .stats-grid,
      .card-grid,
      .feature-grid {
        display: grid;
        gap: 16px;
      }
      .hero-fact-item,
      .hero-output-item {
        padding-top: 12px;
        border-top: 1px solid var(--line);
      }
      .hero-fact-item:first-child,
      .hero-output-item:first-child {
        padding-top: 0;
        border-top: none;
      }
      .hero-fact-label,
      .hero-output-year,
      .output-meta,
      .meta-label,
      .item-kicker {
        margin: 0 0 4px;
        color: var(--accent);
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        font-weight: 600;
      }
      .hero-fact-value,
      .meta-value {
        margin: 0;
        color: var(--text);
        line-height: 1.5;
        font-weight: 400;
      }
      .hero-output-item h3,
      .card h3,
      .card h4 {
        margin: 0 0 6px;
        font-size: 1.05rem;
        color: var(--text);
        line-height: 1.4;
        font-weight: 600;
      }
      .hero-output-item p { margin: 0; }
      .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 24px;
        margin-top: 36px;
      }
      .panel,
      .panel-primary,
      .panel-secondary { padding: 32px; }
      .span-8 { grid-column: span 8; }
      .span-7 { grid-column: span 7; }
      .span-6 { grid-column: span 6; }
      .span-5 { grid-column: span 5; }
      .span-4 { grid-column: span 4; }
      .span-12 { grid-column: span 12; }
      .section-title {
        margin: 0 0 8px;
        font-size: clamp(1.5rem, 2.2vw, 2rem);
        color: var(--text);
        line-height: 1.2;
        letter-spacing: -0.01em;
        font-weight: 700;
      }
      .section-subtitle {
        margin: 0;
        font-size: 0.95rem;
        max-width: 65ch;
      }
      .section-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 18px 24px;
        align-items: start;
        margin-bottom: 24px;
      }
      .section-header > :first-child {
        min-width: 0;
      }
      .list { display: grid; gap: 16px; }
      .card {
        padding: 20px 0;
        border-top: 1px solid var(--line);
      }
      .card:first-child {
        border-top: none;
        padding-top: 0;
      }
      .divider-top {
        border-top: 1px solid var(--line);
        padding-top: 16px;
      }
      .footer {
        padding: 32px 0 48px;
        font-size: 0.9rem;
        border-top: 1px solid var(--line-strong);
      }
      .footer-grid {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: flex-start;
      }
      .footer-copy p { margin: 0; }
      .footer-copy p + p { margin-top: 6px; }
      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: flex-end;
      }
      @media (max-width: 960px) {
        .hero-card {
          grid-template-columns: 1fr;
          gap: 32px;
          padding: 40px;
        }
        .section-header {
          grid-template-columns: 1fr;
        }
        .span-8,
        .span-7,
        .span-6,
        .span-5,
        .span-4 {
          grid-column: span 12;
        }
        .site-header,
        .footer-grid {
          flex-direction: column;
          align-items: flex-start;
        }
        .nav,
        .footer-links {
          justify-content: flex-start;
        }
        .grid {
          gap: 24px;
        }
        .panel,
        .panel-primary,
        .panel-secondary {
          padding: 24px;
        }
      }
      @media (max-width: 720px) {
        .shell { padding: 20px; }
        .page { padding: 32px 0 64px; }
        .hero-card,
        .panel,
        .panel-primary,
        .panel-secondary { padding: 24px; }
        .hero-copy {
          gap: 16px;
        }
        .hero-copy h1 { font-size: clamp(2.5rem, 12vw, 3.5rem); }
        .hero-links,
        .chip-row,
        .meta-row {
          gap: 8px;
        }
        .grid {
          margin-top: 24px;
          gap: 20px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <div class="brand">
          <h1>{profile.name.en}</h1>
          <p>Academic profile</p>
        </div>
        <nav class="nav">
          {navigation.map((item) => (
            <a href={item.href}>{item.label.en}</a>
          ))}
          <a href={portfolioHref}>Portfolio</a>
        </nav>
      </header>
      <main class="page">
        <slot />
      </main>
      <footer class="footer">
        <div class="footer-grid">
          <div class="footer-copy">
            <p>© 2026 Hong Liu · Xiamen University</p>
            <p>Academic homepage with cross-links to project portfolio and public research profiles.</p>
          </div>
          <div class="footer-links">
            <a href={portfolioHref}>Portfolio</a>
            {profile.links.map((link) => (
              <a class="icon-link" href={link.href} target="_blank" rel="noreferrer" aria-label={link.label} title={link.label}>
                <span class="icon-link-icon" set:html={`<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">${iconMap[link.icon]}</svg>`} />
              </a>
            ))}
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
