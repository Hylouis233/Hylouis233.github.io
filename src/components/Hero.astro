---
import { profile, iconMap } from '../data/profile';
import { projects, publications } from '../data/academic';

const evidenceItems = [
  {
    label: 'First-author work',
    value: publications.filter((item) => item.authorshipRank === 'lead').length,
  },
  {
    label: 'Published papers',
    value: publications.filter((item) => item.category === 'publication').length,
  },
  {
    label: 'Public repositories',
    value: projects.filter((item) => item.repoUrl).length,
  },
];

const selectedOutputs = publications.filter((item) => item.featured).slice(0, 2);
const quickFacts = [
  {
    label: 'Current Affiliation',
    value: '<strong>Macau University of Science and Technology</strong><br />M.Sc. student, Faculty of Innovation Engineering<br />Full scholarship and living allowance, supervised by Academician Nanshan Zhong and Prof. Chitin Hon<br />Co-supervised by <a href="https://www.ctmodelling.cn/" target="_blank" rel="noreferrer" style="text-decoration: underline;">Prof. Tianmu Chen</a> (Xiamen University)',
  },
  {
    label: 'Ph.D. Training',
    value: '<strong>Xiamen University</strong><br />Ph.D. student in Epidemiology and Health Statistics, School of Public Health<br />Supervised by <a href="https://www.ctmodelling.cn/" target="_blank" rel="noreferrer" style="text-decoration: underline;">Prof. Tianmu Chen</a>',
  },
  {
    label: 'Undergraduate',
    value: '<strong>Xiamen University</strong><br />B.Med. in Preventive Medicine, School of Public Health<br />Supervised by <a href="https://www.ctmodelling.cn/" target="_blank" rel="noreferrer" style="text-decoration: underline;">Prof. Tianmu Chen</a><br /><br />B.Econ. in Statistics, Wang Yanan Institute for Studies in Economics (WISE)',
  },
];
const heroMeta = [
  'Macau University of Science and Technology (M.Sc., Full scholarship and living allowance)',
  'Xiamen University (Ph.D. & B.Sc.)',
  'Interdisciplinary background spanning public health, epidemiology, AI, and data science'
];
const heroSecondaryNarrative =
  'Current work links multimodal forecasting, epidemic dynamics, and interpretable analytical workflows, with longer-term research extending toward viral evolution and early-warning systems.';
---
<section class="hero-card">
  <div class="hero-copy">
    <p class="eyebrow">Academic homepage</p>
    <h1>{profile.name.en}</h1>
    <p class="headline">{profile.headline.en}</p>

    <div class="hero-supporting-stack">
      <div class="hero-meta" aria-label="Academic affiliation and training">
        {heroMeta.map((item) => (
          <span class="hero-meta-item">{item}</span>
        ))}
      </div>
      <p class="summary">{profile.intro.en}</p>
      <p class="summary summary-secondary">{heroSecondaryNarrative}</p>
    </div>

    <div class="evidence-strip">
      <div class="evidence-intro">
        <p class="eyebrow">Research evidence</p>
        <p class="evidence-note">A concise evidence band keeps the first screen anchored in outputs rather than ornament.</p>
      </div>
      <div class="evidence-grid">
        {evidenceItems.map((item) => (
          <article class="evidence-item">
            <p class="evidence-value">{item.value}</p>
            <p class="evidence-label">{item.label}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="hero-links-wrap">
      <p class="hero-links-label">Profiles and quick routes</p>
      <div class="hero-links" aria-label="Academic profile links">
        {profile.links.map((link) => (
          <a class="icon-link" href={link.href} target="_blank" rel="noreferrer" aria-label={link.label} title={link.label}>
            <span class="icon-link-icon" set:html={`<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">${iconMap[link.icon]}</svg>`} />
          </a>
        ))}
        <a href="/publications/">Selected outputs</a>
        <a href="/cv/">View CV</a>
        <a href={profile.portfolioHref}>Portfolio</a>
      </div>
    </div>
  </div>

  <div class="hero-side">
    <div class="hero-image-wrap">
      <div class="portrait-frame">
        <img src={profile.profileImage} alt="Hong Liu profile" class="hero-image" />
      </div>
    </div>
    <div class="hero-facts-card">
      <p class="eyebrow">Academic identity</p>
      <div class="hero-facts-list">
        {quickFacts.map((item) => (
          <article class="hero-fact-item">
            <p class="hero-fact-label">{item.label}</p>
            <p class="hero-fact-value" set:html={item.value}></p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-supporting-stack {
    display: grid;
    gap: 10px;
    margin-top: 0;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    align-items: center;
  }

  .hero-meta-item {
    padding: 5px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(29, 36, 48, 0.05);
    color: var(--muted-soft);
    font-size: 0.78rem;
    line-height: 1.34;
  }

  .evidence-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.84fr) minmax(0, 1.16fr);
    align-items: start;
    gap: 16px;
    margin-top: 10px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(245, 245, 245, 0.6));
  }

  .evidence-intro {
    display: grid;
    gap: 4px;
  }

  .evidence-note {
    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.5;
    max-width: 36ch;
  }

  .evidence-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .evidence-item {
    padding: 15px 15px 14px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(29, 36, 48, 0.05);
  }

  .evidence-value {
    margin: 0;
    font-size: 1.82rem;
    line-height: 1;
    color: var(--accent);
  }

  .evidence-label {
    margin: 8px 0 0;
    color: var(--muted);
    line-height: 1.4;
    font-size: 0.84rem;
  }

  .hero-links-wrap {
    display: grid;
    gap: 8px;
    margin-top: 0;
  }

  .hero-links-label {
    margin: 0;
    color: var(--muted-soft);
    font-size: 0.76rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-links :global(a:not(.icon-link)) {
    background: rgba(255, 255, 255, 0.4);
    border: 1px solid rgba(29, 36, 48, 0.045);
  }

  .portrait-frame {
    display: inline-flex;
    padding: 14px;
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(245, 245, 245, 0.6));
    border: 1px solid rgba(29, 36, 48, 0.05);
    box-shadow: var(--shadow);
  }

  .hero-facts-card {
    background: rgba(255, 255, 255, 0.38);
    border-color: rgba(29, 36, 48, 0.045);
    box-shadow: none;
  }

  @media (max-width: 720px) {
    .evidence-strip {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .evidence-grid {
      grid-template-columns: 1fr;
    }

    .portrait-frame {
      padding: 10px;
    }
  }
</style>
