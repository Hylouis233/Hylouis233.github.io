---
import { profile } from '../data/profile';
import { projects, publications } from '../data/academic';

const iconMap = {
  orcid: '<path d="M9.9 7.8h4.2v13.4H9.9z"/><path d="M12 4.5a2.4 2.4 0 1 1 0 4.8 2.4 2.4 0 0 1 0-4.8Zm5.7 6.6c2.7 0 4.7 2 4.7 5.1 0 3.1-2 5.1-4.8 5.1h-4.4V11.1h4.5Zm-.4 2.5h-1.7v5.2h1.7c1.4 0 2.4-1 2.4-2.6 0-1.6-.9-2.6-2.4-2.6Z"/>',
  github: '<path d="M12 .6C5.7.6.7 5.6.7 11.9c0 5 3.2 9.1 7.6 10.6.6.1.8-.3.8-.6v-2.2c-3.1.7-3.7-1.3-3.7-1.3-.5-1.3-1.2-1.7-1.2-1.7-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 .1 1.9.7 2.3 1.8.9 1.5 2.3 1.1 2.8.8.1-.7.4-1.1.7-1.4-2.5-.3-5.2-1.2-5.2-5.5 0-1.2.4-2.2 1.2-3-.1-.3-.5-1.4.1-2.9 0 0 .9-.3 3 .9a10.4 10.4 0 0 1 5.4 0c2.1-1.2 3-.9 3-.9.6 1.5.2 2.6.1 2.9.8.8 1.2 1.8 1.2 3 0 4.3-2.7 5.2-5.2 5.5.4.4.8 1.1.8 2.1v3.1c0 .3.2.7.8.6 4.4-1.5 7.6-5.6 7.6-10.6C23.3 5.6 18.3.6 12 .6Z"/>',
  scholar: '<path d="M12 2 1 8l11 6 9-4.9V17h2V8L12 2Zm-6.8 9.3V15c0 2.8 4.1 5 6.8 5s6.8-2.2 6.8-5v-3.7L12 15l-6.8-3.7Z"/>',
  researchgate: '<path d="M5.5 3.2h7.2c4 0 6.5 2 6.5 5.6 0 2.5-1.4 4.3-3.7 5.1l4.1 6.9h-4.2l-3.6-6.3H9.2v6.3H5.5V3.2Zm6.8 8.1c2 0 3.1-.8 3.1-2.4s-1.1-2.4-3.1-2.4H9.2v4.8h3.1Z"/><path d="M4.3 16.3h4.5v4.5H4.3z"/>',
  email: '<path d="M2.3 5.5h19.4a1.3 1.3 0 0 1 1.3 1.3v10.4a1.3 1.3 0 0 1-1.3 1.3H2.3A1.3 1.3 0 0 1 1 17.2V6.8a1.3 1.3 0 0 1 1.3-1.3Zm9.7 6 9-5.2H3l9 5.2Zm0 1.6-9-5.1v8h18v-8l-9 5.1Z"/>',
} as const;

const evidenceItems = [
  {
    label: 'First-author work',
    value: publications.filter((item) => item.authorshipRank === 'lead').length,
  },
  {
    label: 'Published papers',
    value: publications.filter((item) => item.category === 'publication').length,
  },
  {
    label: 'Public repositories',
    value: projects.filter((item) => item.repoUrl).length,
  },
];

const selectedOutputs = publications.filter((item) => item.featured).slice(0, 2);
const quickFacts = [
  {
    label: 'Affiliation',
    value: profile.affiliation.en,
  },
  {
    label: 'Current stage',
    value: 'M.Sc. student working on infectious disease forecasting and analytical systems',
  },
  {
    label: 'Location',
    value: profile.location.en,
  },
];
const heroMeta = [profile.affiliation.en, profile.degrees.en].filter(Boolean);
const heroSecondaryNarrative =
  'Current work links multimodal forecasting, epidemic dynamics, and interpretable analytical workflows, with longer-term research extending toward viral evolution and early-warning systems.';
---
<section class="hero-card">
  <div class="hero-copy">
    <p class="eyebrow">Academic homepage</p>
    <h1>{profile.name.en}</h1>
    <p class="headline">{profile.headline.en}</p>
    <div class="hero-meta" aria-label="Academic affiliation and training">
      {heroMeta.map((item) => (
        <span class="hero-meta-item">{item}</span>
      ))}
    </div>
    <p class="summary">{profile.intro.en}</p>
    <p class="summary summary-secondary">{heroSecondaryNarrative}</p>

    <div class="evidence-strip">
      <p class="eyebrow">Research evidence</p>
      <div class="evidence-grid">
        {evidenceItems.map((item) => (
          <article class="evidence-item">
            <p class="evidence-value">{item.value}</p>
            <p class="evidence-label">{item.label}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="hero-links" aria-label="Academic profile links">
      {profile.links.slice(0, 4).map((link) => (
        <a class="icon-link" href={link.href} target="_blank" rel="noreferrer" aria-label={link.label} title={link.label}>
          <span class="icon-link-icon" set:html={iconMap[link.icon]} />
        </a>
      ))}
      <a href="/publications/">Selected outputs</a>
      <a href="/cv/">View CV</a>
      <a href={profile.portfolioHref}>Portfolio</a>
    </div>
  </div>

  <div class="hero-side">
    <div class="hero-image-wrap">
      <img src={profile.profileImage} alt="Hong Liu profile" class="hero-image" />
    </div>
    <div class="hero-facts-card">
      <p class="eyebrow">Academic identity</p>
      <div class="hero-facts-list">
        {quickFacts.map((item) => (
          <article class="hero-fact-item">
            <p class="hero-fact-label">{item.label}</p>
            <p class="hero-fact-value">{item.value}</p>
          </article>
        ))}
      </div>
    </div>
    <div class="hero-output-card">
      <p class="eyebrow">Selected lead outputs</p>
      <div class="hero-output-list">
        {selectedOutputs.map((item) => (
          <article class="hero-output-item">
            <p class="hero-output-year">{item.year} · {item.authorship?.en}</p>
            <h3>{item.title.en}</h3>
            <p>{item.venue.en} · {item.status.en}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .hero-meta-item {
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(29, 36, 48, 0.08);
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .evidence-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .evidence-item {
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(29, 36, 48, 0.08);
  }

  .evidence-value {
    margin: 0;
    font-size: 1.8rem;
    line-height: 1;
    color: var(--accent);
  }

  .evidence-label {
    margin: 8px 0 0;
    color: var(--muted);
    line-height: 1.45;
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .evidence-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
